{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "dev:all": "concurrently \"php artisan serve --host=localhost --port=8000\" \"vite\"",
        "dev:all:host": "concurrently \"php artisan serve --host=[IP_ADDRESS] --port=8000\" \"vite\"",
        "dev:dev": "concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve --host=localhost --port=8000\" \"php artisan queue:work --tries=1\" \"php artisan pail\" \"pnpm run dev\" --names=server,queue,logs,vite --kill-others"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^2.0.0",
        "tailwindcss": "^4.0.0",
        "vite": "^7.0.7"
    }
}